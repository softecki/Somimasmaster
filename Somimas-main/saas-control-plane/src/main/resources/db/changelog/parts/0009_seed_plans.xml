<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0009-seed-entitlements" author="somimas">
        <insert tableName="cp_entitlement">
            <column name="code" value="max_users"/>
            <column name="description" value="Maximum active users"/>
        </insert>
        <insert tableName="cp_entitlement">
            <column name="code" value="max_branches"/>
            <column name="description" value="Maximum branches"/>
        </insert>
        <insert tableName="cp_entitlement">
            <column name="code" value="api_access"/>
            <column name="description" value="API access enabled"/>
        </insert>
        <insert tableName="cp_entitlement">
            <column name="code" value="custom_domain"/>
            <column name="description" value="Custom domain support"/>
        </insert>
    </changeSet>

    <changeSet id="0009-seed-plans" author="somimas">
        <insert tableName="cp_plan">
            <column name="code" value="starter"/>
            <column name="name" value="Starter"/>
            <column name="description" value="Entry plan for small MFIs"/>
            <column name="status" value="ACTIVE"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>
        <insert tableName="cp_plan">
            <column name="code" value="growth"/>
            <column name="name" value="Growth"/>
            <column name="description" value="Growing institutions"/>
            <column name="status" value="ACTIVE"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>
        <insert tableName="cp_plan">
            <column name="code" value="enterprise"/>
            <column name="name" value="Enterprise"/>
            <column name="description" value="Large-scale deployments"/>
            <column name="status" value="ACTIVE"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>
    </changeSet>

    <changeSet id="0009-seed-plan-prices" author="somimas">
        <insert tableName="cp_plan_price">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='starter')"/>
            <column name="currency" value="USD"/>
            <column name="amount" value="49.000000"/>
            <column name="billing_interval" value="MONTHLY"/>
            <column name="active" valueBoolean="true"/>
        </insert>
        <insert tableName="cp_plan_price">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='growth')"/>
            <column name="currency" value="USD"/>
            <column name="amount" value="149.000000"/>
            <column name="billing_interval" value="MONTHLY"/>
            <column name="active" valueBoolean="true"/>
        </insert>
        <insert tableName="cp_plan_price">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='enterprise')"/>
            <column name="currency" value="USD"/>
            <column name="amount" value="499.000000"/>
            <column name="billing_interval" value="MONTHLY"/>
            <column name="active" valueBoolean="true"/>
        </insert>
    </changeSet>

    <changeSet id="0009-seed-plan-entitlements" author="somimas">
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='starter')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='max_users')"/>
            <column name="value" value="5"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='starter')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='max_branches')"/>
            <column name="value" value="1"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='starter')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='api_access')"/>
            <column name="value" value="false"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='growth')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='max_users')"/>
            <column name="value" value="25"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='growth')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='max_branches')"/>
            <column name="value" value="5"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='growth')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='api_access')"/>
            <column name="value" value="true"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='enterprise')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='max_users')"/>
            <column name="value" value="unlimited"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='enterprise')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='max_branches')"/>
            <column name="value" value="unlimited"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='enterprise')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='api_access')"/>
            <column name="value" value="true"/>
        </insert>
        <insert tableName="cp_plan_entitlement">
            <column name="plan_id" valueComputed="(SELECT id FROM cp_plan WHERE code='enterprise')"/>
            <column name="entitlement_id" valueComputed="(SELECT id FROM cp_entitlement WHERE code='custom_domain')"/>
            <column name="value" value="true"/>
        </insert>
    </changeSet>

</databaseChangeLog>
