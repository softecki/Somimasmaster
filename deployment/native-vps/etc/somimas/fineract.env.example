# Somimas Fineract runtime configuration
# Copy to /etc/somimas/fineract.env and replace CHANGE_ME values before first deploy.
# Permissions: root:somimas 640

# --- Server (TLS terminated at Nginx) ---
FINERACT_SERVER_PORT=8080
FINERACT_SERVER_SSL_ENABLED=false
FINERACT_INSECURE_HTTP_CLIENT=false

# --- Tenant registry database (fineract_tenants) ---
FINERACT_HIKARI_DRIVER_SOURCE_CLASS_NAME=org.mariadb.jdbc.Driver
FINERACT_HIKARI_JDBC_URL=jdbc:mariadb://127.0.0.1:3306/fineract_tenants
FINERACT_HIKARI_USERNAME=somimas_fineract
FINERACT_HIKARI_PASSWORD=skdcnwauicn2ucnaecasdsajdnizucawencascdca
FINERACT_HIKARI_MINIMUM_IDLE=3
FINERACT_HIKARI_MAXIMUM_POOL_SIZE=20
FINERACT_HIKARI_CONNECTION_TIMEOUT=20000
FINERACT_HIKARI_TEST_QUERY=SELECT 1

# --- Default tenant bootstrap (fineract_default) ---
FINERACT_DEFAULT_TENANTDB_HOSTNAME=127.0.0.1
FINERACT_DEFAULT_TENANTDB_PORT=3306
FINERACT_DEFAULT_TENANTDB_USERNAME=somimas_fineract
FINERACT_DEFAULT_TENANTDB_PASSWORD=skdcnwauicn2ucnaecasdsajdnizucawencascdca
FINERACT_DEFAULT_TENANTDB_IDENTIFIER=default
FINERACT_DEFAULT_TENANTDB_NAME=fineract_default
FINERACT_DEFAULT_TENANTDB_DESCRIPTION=Default Tenant
FINERACT_DEFAULT_TENANTDB_TIMEZONE=Africa/Nairobi
FINERACT_DEFAULT_TENANTDB_MASTER_PASSWORD=skdcnwauicn2ucnaecasdsajdnizucawencascdca

# --- Content storage ---
FINERACT_CONTENT_FILESYSTEM_ENABLED=true
FINERACT_CONTENT_FILESYSTEM_ROOT_FOLDER=/var/lib/somimas/fineract-content

# --- SaaS provisioning bridge (custom/somimas/saas) ---
# Edit the JSON below with the same bridge token used in control-plane.env
SPRING_APPLICATION_JSON={"server":{"address":"127.0.0.1"},"somimas":{"saas":{"enabled":true,"bridge":{"token":"CHANGE_ME_SHARED_BRIDGE_TOKEN"},"db":{"admin-url":"jdbc:mariadb://127.0.0.1:3306/","admin-username":"somimas_provisioner","admin-password":"skdcnwauicn2ucnaecasdsajdnizucawencascdca"},"encrypt-passwords":true,"entitlement":{"report-only":true}}}}

# --- Security hardening ---
FINERACT_SECURITY_HSTS_ENABLED=true
FINERACT_INSECURE_HTTP_CLIENT=false
FINERACT_SERVER_SSL_ENABLED=false

# --- Observability ---
FINERACT_MANAGEMENT_ENDPOINT_WEB_EXPOSURE_INCLUDE=health,info
FINERACT_MANAGEMENT_METRICS_TAGS_APPLICATION=fineract
FINERACT_NODE_ID=1

# --- JVM (override in /etc/somimas/fineract.jvm.opts for large instances) ---
JAVA_OPTS=-Xms512m -Xmx1536m -XX:+UseG1GC -XX:MaxRAMPercentage=75
