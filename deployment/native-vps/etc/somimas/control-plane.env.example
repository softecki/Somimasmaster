# Somimas SaaS Control Plane runtime configuration
# Copy to /etc/somimas/control-plane.env and replace CHANGE_ME values before first deploy.
# Permissions: root:somimas 640

# --- Server (TLS terminated at Nginx) ---
SERVER_PORT=8090
SERVER_ADDRESS=127.0.0.1
SERVER_SERVLET_CONTEXT_PATH=/saas-api

# --- Control-plane database ---
SPRING_DATASOURCE_URL=jdbc:mariadb://127.0.0.1:3306/somimas_control
SPRING_DATASOURCE_USERNAME=somimas_control
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_CONTROL_PLANE_DB_PASSWORD
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_LIQUIBASE_ENABLED=true

# --- Fineract provisioning bridge ---
SOMIMAS_FINERACT_BRIDGE_URL=http://127.0.0.1:8080/fineract-provider
SOMIMAS_FINERACT_BRIDGE_TOKEN=CHANGE_ME_BRIDGE_TOKEN

# --- Auth (local | oidc) ---
SOMIMAS_AUTH_MODE=local
SOMIMAS_AUTH_JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
SOMIMAS_AUTH_PLATFORM_ADMIN_EMAILS=admin@softecki.com

# --- Trial & billing ---
SOMIMAS_TRIAL_DAYS=14
SOMIMAS_APP_DOMAIN=microfinance.softecki.com

# --- Flutterwave (optional; leave blank until Phase 3) ---
SOMIMAS_FLUTTERWAVE_SECRET_HASH=
SOMIMAS_FLUTTERWAVE_PUBLIC_KEY=
SOMIMAS_FLUTTERWAVE_SECRET_KEY=

# --- Receipt uploads ---
SOMIMAS_RECEIPTS_STORAGE_PATH=/var/lib/somimas/receipts

# --- Observability ---
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized

# --- JVM ---
JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC
